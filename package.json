{
  "name": "scroll-craft",
  "version": "0.1.0",
  "description": "Tiny TypeScript scroll animation library — blur reveal, reveal, counter, progress, stagger, text reveal, and zoom effects with zero dependencies",
  "author": "Bilal <hello@bilalstudio.io>",
  "license": "MIT",
  "homepage": "https://github.com/Bilal-Studios/scroll-craft#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bilal-Studios/scroll-craft.git"
  },
  "keywords": [
    "scroll",
    "animation",
    "intersection-observer",
    "blur-reveal",
    "reveal",
    "counter",
    "scroll-progress",
    "stagger",
    "text-reveal",
    "zoom",
    "typescript",
    "zero-dependency"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
